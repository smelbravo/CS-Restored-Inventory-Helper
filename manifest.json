{
  "manifest_version": 3,
  "name": "CS:Restored Inventory Helper",
  "version": "3.0.7",
  "description": "Float, seed, and quick-sell tools for Counter-Strike: Restored (csrestored.fun). Unofficial extension.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "*://*.csrestored.fun/*",
    "https://api.csrestored.fun/*",
    "https://cdn.csrestored.fun/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.csrestored.fun/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["*://*.csrestored.fun/*"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "csr-inventory-seller@csrestored.local",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
