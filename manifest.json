{

  "manifest_version": 3,

  "name": "CS:Restored Inventory Helper",

  "version": "3.8.4",

  "description": "Float, seed, quick sell, case bulk buy, auto case opening, session auto-sell, multi-language UI, and skin lock for CS:Restored (csrestored.fun). Unofficial extension.",

  "icons": {

    "16": "icons/icon-16.png",

    "48": "icons/icon-48.png",

    "128": "icons/icon-128.png"

  },

  "permissions": [

    "storage",

    "downloads",

    "tabs"

  ],

  "action": {

    "default_popup": "src/popup/popup.html",

    "default_title": "CS:Restored Inventory Helper — settings"

  },

  "host_permissions": [

    "*://*.csrestored.fun/*",

    "https://api.csrestored.fun/*",

    "https://cdn.csrestored.fun/*",

    "https://api.github.com/*",

    "https://api.counterapi.dev/*"

  ],

  "content_scripts": [

    {

      "matches": ["*://*.csrestored.fun/*"],

      "js": [
        "src/lib/csr-storage.js",
        "src/lib/i18n-packs.js",
        "src/lib/i18n-packs-generated.js",
        "src/lib/i18n.js",
        "src/lib/settings.js",
        "src/lib/skin-patterns.js",
        "src/content.js"
      ],

      "run_at": "document_idle"

    }

  ],

  "web_accessible_resources": [

    {

      "resources": ["icons/*.png", "docs/CHANGELOG.md", "data/csr-doppler-item-map.json"],

      "matches": ["*://*.csrestored.fun/*"]

    }

  ],

  "browser_specific_settings": {

    "gecko": {

      "id": "csr-inventory-seller@csrestored.local",

      "strict_min_version": "128.0",

      "data_collection_permissions": {

        "required": ["none"]

      }

    }

  }

}
