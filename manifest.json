{

  "manifest_version": 3,

  "name": "CS:Restored Inventory Helper",

  "version": "3.6.0",

  "description": "Float, seed, quick sell, case bulk buy, auto case opening, session auto-sell, multi-language UI, and skin lock for CS:Restored (csrestored.fun). Unofficial extension.",

  "icons": {

    "16": "icons/icon-16.png",

    "48": "icons/icon-48.png",

    "128": "icons/icon-128.png"

  },

  "permissions": [

    "storage"

  ],

  "action": {

    "default_popup": "popup.html",

    "default_title": "CS:Restored Inventory Helper — settings"

  },

  "host_permissions": [

    "*://*.csrestored.fun/*",

    "https://api.csrestored.fun/*",

    "https://cdn.csrestored.fun/*",

    "https://api.github.com/*"

  ],

  "content_scripts": [

    {

      "matches": ["*://*.csrestored.fun/*"],

      "js": ["i18n-packs.js", "i18n-packs-generated.js", "i18n.js", "settings.js", "content.js"],

      "run_at": "document_idle"

    }

  ],

  "web_accessible_resources": [

    {

      "resources": ["icons/*.png", "CHANGELOG.md"],

      "matches": ["*://*.csrestored.fun/*"]

    }

  ],

  "browser_specific_settings": {

    "gecko": {

      "id": "csr-inventory-seller@csrestored.local",

      "strict_min_version": "140.0",

      "data_collection_permissions": {

        "required": ["none"]

      }

    }

  }

}

